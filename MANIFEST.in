include README.md
include README.zh.md
include LICENSE
include CHANGELOG.md
include pyproject.toml
include requirements.txt

recursive-include pdf2md *.py

recursive-include tests *.py
recursive-include docs *.md
recursive-include fixtures *

prune __pycache__
prune *.egg-info
prune .pytest_cache
prune .mypy_cache
prune .tox
prune htmlcov
prune *.dist-info
prune build
prune dist